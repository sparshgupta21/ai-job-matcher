# ─────────────────────────────────────────────
# AI Job Matcher v2.0 — Environment Variables
# ─────────────────────────────────────────────

# HuggingFace API Token (REQUIRED for AI features)
# Get free at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Tavily Search API Key (recommended for real job search)
# Get free at: https://tavily.com (1,000 searches/month)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxx

# JSearch API Key via RapidAPI (optional, 200 free/month)
# Get at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# Adzuna API (optional)
# Register at: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# Serper Search API (optional, 2500 free credits one-time)
# Get at: https://serper.dev
SERPER_API_KEY=
