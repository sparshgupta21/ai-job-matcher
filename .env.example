# ─────────────────────────────────────────────
# AI Job Matcher - Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# Or set these as environment variables directly

# REQUIRED: HuggingFace API Token (free)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# OPTIONAL: JSearch API Key (via RapidAPI, free tier: 200 req/month)
# Get yours at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# OPTIONAL: Adzuna API Credentials (free developer account)
# Get yours at: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_API_KEY=
